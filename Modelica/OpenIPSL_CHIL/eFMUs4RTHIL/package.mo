within OpenIPSL_CHIL;
package eFMUs4RTHIL
  "Models of the plant to generate eFMUs of the plant to be used for real-time hardware-in-the-loop (RT-HIL) simulation."
  extends Modelica.Icons.Package;
  annotation (Icon(graphics={Text(
          extent={{-100,100},{100,-100}},
          textColor={0,0,0},
          textString="RTS")}));
end eFMUs4RTHIL;
