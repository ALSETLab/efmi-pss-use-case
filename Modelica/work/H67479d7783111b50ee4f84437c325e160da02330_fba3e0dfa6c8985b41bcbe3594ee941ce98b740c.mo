    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3SetFloat643D(void*m, int* refs, int nrefs, const double* vals, int nvals1, int nvals2, int nvals3){
        struct dy_fmi3Extended *a = m;
