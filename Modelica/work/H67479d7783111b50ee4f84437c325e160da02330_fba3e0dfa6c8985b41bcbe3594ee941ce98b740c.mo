    function fmi3EnterConfigurationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      external "C" fmi_wrapper_fmi3EnterConfigurationMode(fmu)
      annotation(Include="
    #ifndef FMU_fmi3EnterConfigurationMode_C
    #define FMU_fmi3EnterConfigurationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3EnterConfigurationMode(void*m){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if (a->currentMode == dyfmi3InstantiationMode);
          {
            status = a->dyFmiEnterConfigurationMode(a->m);
            if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterContinuousTimeMode failed!\");
            a->currentMode == dyfmi3ConfigurationMode;
          }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterConfigurationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://H67479d7783111b50ee4f84437c325e160da02330_fba3e0dfa6c8985b41bcbe3594ee941ce98b740c/Resources/Library/FMU/H67479d7783111b50ee4f84437c325e160da02330_fba3e0dfa6c8985b41bcbe3594ee941ce98b740c/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3EnterConfigurationMode;

    function fmi3ExitConfigurationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      external "C" fmi_wrapper_fmi3ExitConfigurationMode(fmu)
      annotation(Include="
    #ifndef FMU_fmi3ExitConfigurationMode_C
    #define FMU_fmi3ExitConfigurationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3ExitConfigurationMode(void*m){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if (a->currentMode == dyfmi3ConfigurationMode);
          {
            status = a->dyFmiExitConfigurationMode(a->m);
            if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterContinuousTimeMode failed!\");
            a->currentMode == dyfmi3InstantiationMode;
          }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3ExitConfigurationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://H67479d7783111b50ee4f84437c325e160da02330_fba3e0dfa6c8985b41bcbe3594ee941ce98b740c/Resources/Library/FMU/H67479d7783111b50ee4f84437c325e160da02330_fba3e0dfa6c8985b41bcbe3594ee941ce98b740c/binaries");
