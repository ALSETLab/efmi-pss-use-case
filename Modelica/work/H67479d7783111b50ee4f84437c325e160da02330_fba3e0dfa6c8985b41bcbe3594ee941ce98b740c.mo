    function fmi3SetFloat64
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer refs[:];
      input Real vals[:];
      external "C" fmi_wrapper_fmi3SetFloat64(fmu, refs, size(refs, 1), vals, size(vals, 1))
