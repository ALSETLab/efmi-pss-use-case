        annotation(Include="
      #ifndef FMU_Instantiate_C
      #define FMU_Instantiate_C
      #include <stdlib.h>
      #include \"FMI/fmi3Import.h\"
        void fmi_wrapper_Logger(fmi3InstanceEnvironment instanceEnvironment, fmi3Status status, fmi3String category,fmi3String message){
          char msg[4096];
          int len;
        #if defined(_MSC_VER) && _MSC_VER >= 1200
          len = _snprintf(msg, sizeof(msg)/sizeof(*msg),\"%s\", message);
          if (len < 0) goto fail;
        #else
          len = snprintf(msg, sizeof(msg)/sizeof(*msg),\"%s\", message);
          if (len < 0) goto fail;
        #endif
          if(len>0 && len<4096 && msg[len - 1]!='\\n'){
            msg[len] = '\\n';
            msg[len+1] = 0;
          }
          switch (status){
            case fmi3Fatal:
              ModelicaMessage(\"[fmi3Fatal]: \");
              break;
            case fmi3Error:
              ModelicaMessage(\"[fmi3Error]: \");
              break;
            case fmi3Discard:
              ModelicaMessage(\"[fmi3Discard]: \");
              break;
            case fmi3Warning:
              ModelicaMessage(\"[fmi3Warning]: \");
              break;
            case fmi3OK:
              ModelicaMessage(\"[fmi3OK]: \");
              break;
          }
          ModelicaMessage(msg);
          return;
        fail:
          ModelicaMessage(\"Logger failed, message too long?\");
        }

