    function fmi3GetBoolean
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer refs[:];
      input Integer nbrVals;
      input Integer dummyTime;
      output Boolean vals[nbrVals];
      external "C" fmi_wrapper_fmi3GetBoolean(fmu, refs, size(refs, 1), vals, nbrVals)
      annotation(Include="
    #ifndef FMU_fmi3GetBoolean_C
    #define FMU_fmi3GetBoolean_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3GetBoolean(void*m, int* refs, int nrefs, int* vals, int nvals){
        fmi3Int32 ind = 0;
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          status=a->dyFmiGetBoolean(a->m, refs, nrefs, (fmi3Boolean*) vals, nvals);
          for(ind=nvals-1; ind >= 0; --ind) vals[ind]=((fmi3Boolean*)(vals))[ind];
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3GetBoolean failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3GetBoolean;

    function fmi3SetBoolean
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer refs[:];
      input Boolean vals[:];
    protected
      Boolean dummy[size(vals, 1)];
      external "C" fmi_wrapper_fmi3SetBoolean(fmu, refs, size(refs, 1), vals, size(vals, 1), dummy)
      annotation(Include="
    #ifndef FMU_fmi3SetBoolean_C
    #define FMU_fmi3SetBoolean_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3SetBoolean(void*m, int* refs, int nrefs, const int* vals, int nvals, int* dummy){
        fmi3Int32 ind = 0;
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if(!a->discreteInputChanged){
            status=a->dyFmiGetBoolean(a->m, refs, nrefs, (fmi3Boolean*) dummy, nvals);
            for(ind=nvals-1; ind >= 0; --ind)
              if (((fmi3Boolean*)(dummy))[ind] != (fmi3Boolean)vals[ind]){
                a->discreteInputChanged = 1;
                break;
              }
          }
          if(a->discreteInputChanged){
            for(ind=nvals-1; ind >= 0; --ind) ((fmi3Boolean*)(dummy))[ind]=(fmi3Boolean)vals[ind];
            status=a->dyFmiSetBoolean(a->m, refs, nrefs, (fmi3Boolean*) dummy, nvals);
          }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3SetBoolean failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true,
        __Dymola_IdemPotent=true,
        __Dymola_VectorizedExceptFirst=true);
    end fmi3SetBoolean;

