    function fmi3GetScalarOutput32
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer ind;
      output Real dx;
      external "C" fmi_wrapper_fmi3GetScalarOutput32(fmu,  dx, ind)
      annotation(Include="
    #ifndef FMU_fmi3GetScalarOutput32_C
    #define FMU_fmi3GetScalarOutput32_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3GetScalarOutput32(void*m, double* dx,int ind){
        const size_t nvr = 5;
        const size_t nval = 5;
        static const int vr[5] = {3, 4, 5, 6, 7};
        static const int vrPos[6] = {0, 1, 2, 3, 4, 5};
        const size_t pos = vrPos[ind];
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if(a->cpOut32){
            status = a->dyFmiGetFloat32(a->m, vr, nvr, a->out32, nval);
            a->cpOut32 = 0;
          } else { status = fmi3OK; }
          *dx = a->out32[pos];
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3GetScalarOutput32 failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3GetScalarOutput32;

    function fmi3DoStep
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Real currentTime;
      input Real stepSize;
      external "C" fmi_wrapper_fmi3DoStep(fmu,  currentTime, stepSize)
      annotation(Include="
    #ifndef FMU_fmi3DoStep_C
    #define FMU_fmi3DoStep_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3DoStep(void*m, double currentTime, double stepSize){
        fmi3Float64 currentCommunicationPoint = 0.0;
        fmi3Float64 communicationStepSize = 0.0;
        fmi3Boolean noSetFMUStatePriorToCurrentPoint = fmi3False;
        fmi3Boolean eventEncountered = fmi3False;
        fmi3Boolean terminateSimulation = fmi3False;
        fmi3Boolean earlyReturn = fmi3False;
        fmi3Float64 lastSuccessfulTime = 0.0;
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          currentCommunicationPoint = (fmi3Float64) currentTime;
          communicationStepSize = (fmi3Float64) stepSize;
          noSetFMUStatePriorToCurrentPoint = fmi3True;
          status=a->dyFmiDoStep(a->m, currentCommunicationPoint, communicationStepSize, noSetFMUStatePriorToCurrentPoint,
          &eventEncountered, &terminateSimulation, &earlyReturn, &lastSuccessfulTime);
          if(terminateSimulation==fmi3True){
            double tt = (double) lastSuccessfulTime;
            char s[64] = {0};
          #if defined(_MSC_VER) && _MSC_VER >= 1200
            if(_snprintf(s, sizeof(s)/sizeof(*s), \"Terminate signaled by the FMU at time %g\", tt) > 0)
          #else
            if(snprintf(s, sizeof(s)/sizeof(*s), \"Terminate signaled by the FMU at time %g\", tt) > 0)
          #endif
            {
              terminate(s);
            } else { terminate(\"Terminate signaled by the FMU\"); }
          }
        }
        if (status!=fmi3OK && status!=fmi3Warning)
        {
          ModelicaFormatError(\"The call of fmi3DoStep(%f, %f) failed in FMU\\nNote: setting fmi_loggingOn in the FMU component may produce more information from the FMU.\",currentTime, stepSize);
        }
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3DoStep;

    function fmi3EnterInitializationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Boolean toleranceDefined;
      input Real tolerance;
      input Real startTime;
      input Boolean stopTimeDefined;
      input Real stopTime;
      external "C" fmi_wrapper_fmi3EnterInitializationMode(fmu, toleranceDefined, tolerance, startTime, stopTimeDefined, stopTime)
      annotation(Include="
    #ifndef FMU_fmi3EnterInitializationMode_C
    #define FMU_fmi3EnterInitializationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3EnterInitializationMode(void*m, int toleranceDefined, double tolerance, double startTime, int stopTimeDefined, double stopTime){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if(a->currentMode==dyfmi3InstantiationMode){
            a->dyTime=startTime;
            status = a->dyFmiEnterInitializationMode(a->m, toleranceDefined, tolerance, startTime, stopTimeDefined, stopTime);
            a->currentMode=dyfmi3InitializationMode;
            a->dyTriggered=0;
            a->dyLastTime=a->dyTime;
          } else { status=fmi3OK; }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterInitializationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3EnterInitializationMode;

    function fmi3ExitModelInitializationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      output Real dummy = 1.0;
      external "C" fmi_wrapper_fmi3ExitModelInitializationMode(fmu)
      annotation(Include="
    #ifndef FMU_fmi3ExitModelInitializationMode_C
    #define FMU_fmi3ExitModelInitializationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3ExitModelInitializationMode(void*m){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if(a->currentMode==dyfmi3InitializationMode){
            status=a->dyFmiExitInitializationMode(a->m);
            a->dyTriggered=0;
            a->dyLastTime=a->dyTime;
            a->currentMode = dyfmi3EventMode;
            a->cpDer = 1;
            a->cpOut = 1;
            a->cpOut32 = 1;
          } else { status = fmi3OK; }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3ExitModelInitializationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3ExitModelInitializationMode;

    function fmi3GetFloat32
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer refs[:];
      input Integer nbrVals;
      input Real dummyTime;
      output Real vals[nbrVals];
      external "C" fmi_wrapper_fmi3GetFloat32(fmu, refs, size(refs, 1), vals, nbrVals)
      annotation(Include="
    #ifndef FMU_fmi3GetFloat32_C
    #define FMU_fmi3GetFloat32_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3GetFloat32(void*m, int* refs, int nrefs, double* vals, int nvals){
        fmi3Int32 ind = 0;
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          status=a->dyFmiGetFloat32(a->m, refs, nrefs, (fmi3Float32*) vals, nvals);
          for(ind=nvals-1; ind >= 0; --ind) vals[ind]=((fmi3Float32*)(vals))[ind];
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3GetFloat32 failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
