    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3SetFloat32(void*m, int* refs, int nrefs, const double* vals, int nvals, double* dummy){
        fmi3Int32 ind = 0;
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          a->cpDer = 1;
          a->cpOut = 1;
          a->cpOut32 = 1;
          for(ind=nvals-1; ind >= 0; --ind) ((fmi3Float32*)(dummy))[ind]=(fmi3Float32)vals[ind];
          status=a->dyFmiSetFloat32(a->m, refs, nrefs, (fmi3Float32*) dummy, nvals);
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3SetFloat32 failed\");
      }
