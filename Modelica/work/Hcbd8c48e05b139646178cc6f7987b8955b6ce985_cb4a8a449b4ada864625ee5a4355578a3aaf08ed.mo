    function getOutputScalar32
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Real Time;
      input Real Float32Inputs[:];
      input Integer  Float32VRs[:];
      input Boolean BooleanInputs[:];
      input Integer  BooleanVRs[:];
      input Integer outputVr;
      input Integer outputIndex;
      output Real outputVariable;
    algorithm
      fmi3SetFloat32(fmu, Float32VRs, Float32Inputs);
      fmi3SetBoolean(fmu, BooleanVRs, BooleanInputs);
      outputVariable := fmi3GetScalarOutput32(fmu, outputIndex);
      annotation(LateInline=true);
    end getOutputScalar32;

