              ModelicaError(\"GetProcAddress failed for fmi3DoStep!\");
              return 0;
            }
            res->m=res->dyFmiInstantiateCoSimulation(instanceName, \"\", resourcePath, fmi3False, loggingOn, eventModeUsed, earlyReturnAllowed, requiredIntermediateVariables, nRequiredIntermediateVariables, instanceEnvironment, &fmi_wrapper_Logger, intermediateUpdate);
            res->der = calloc(0, sizeof(double));
            res->out = calloc(0, sizeof(double));
            res->dyInstanceEnvironment = instanceEnvironment;
            res->out32 = calloc(5, sizeof(double));
            if(!res->m || !res->der && 0 || !res->out && 0 ) {free(res);res=0;ModelicaError(\"InstantiateModel failed\");}
            else{
              res->dyTriggered=0;
              res->dyTime=res->dyLastTime=-1e37;
              res->discreteInputChanged=1;
              res->currentMode=dyfmi3InstantiationMode;
              res->dyLastStepTime=0;
              res->dyFMUstate=NULL;
            }
          }
          return res;
        }
        #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
        annotation (__Dymola_doNotLinkSharedObject=true,
            __Dymola_CriticalRegion="fmi_wrapper");
      end constructor;

      function destructor
        extends Modelica.Icons.Function;
        input fmuModel fmu;
        external "C" fmi_wrapper_FreeModelInstance(fmu)
        annotation(Include="
      #ifndef FMU_Free_C
      #define FMU_Free_C
      #include <stdlib.h>
      #include \"FMI/fmi3Import.h\"
        void fmi_wrapper_FreeModelInstance(void*m){
          struct dy_fmi3Extended *a = m;
          fmi3Status status=fmi3Fatal;
          if(a){
            a->dyFmiTerminate(a->m);
            a->dyFmiFreeInstance(a->m);
            free(a->der);a->der=0;
            free(a->out);a->out=0;
            free(a->dyInstanceEnvironment);a->dyInstanceEnvironment=0;
            free(a);a=0;
          }
        }
        #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
        annotation (__Dymola_doNotLinkSharedObject=true,
            __Dymola_CriticalRegion="fmi_wrapper");
      end destructor;

    end fmuModel;

    function fmi3EnterConfigurationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      external "C" fmi_wrapper_fmi3EnterConfigurationMode(fmu)
      annotation(Include="
    #ifndef FMU_fmi3EnterConfigurationMode_C
    #define FMU_fmi3EnterConfigurationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3EnterConfigurationMode(void*m){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if (a->currentMode == dyfmi3InstantiationMode);
          {
            status = a->dyFmiEnterConfigurationMode(a->m);
            if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterContinuousTimeMode failed!\");
            a->currentMode == dyfmi3ConfigurationMode;
          }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterConfigurationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
      annotation (
        __Dymola_doNotLinkSharedObject=true,
        __Dymola_CriticalRegion="fmi_wrapper",
        __Dymola_LockExternalObject=true);
    end fmi3EnterConfigurationMode;

    function fmi3ExitConfigurationMode
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      external "C" fmi_wrapper_fmi3ExitConfigurationMode(fmu)
      annotation(Include="
    #ifndef FMU_fmi3ExitConfigurationMode_C
    #define FMU_fmi3ExitConfigurationMode_C
    #include <stdlib.h>
    #include \"FMI/fmi3Import.h\"
      void fmi_wrapper_fmi3ExitConfigurationMode(void*m){
        struct dy_fmi3Extended *a = m;
        fmi3Status status=fmi3Fatal;
        if(a){
          if (a->currentMode == dyfmi3ConfigurationMode);
          {
            status = a->dyFmiExitConfigurationMode(a->m);
            if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3EnterContinuousTimeMode failed!\");
            a->currentMode == dyfmi3InstantiationMode;
          }
        }
        if(status!=fmi3OK && status!=fmi3Warning) ModelicaError(\"fmi3ExitConfigurationMode failed\");
      }
      #endif", Library="fmi_wrapper", LibraryDirectory="modelica://Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/Resources/Library/FMU/Hcbd8c48e05b139646178cc6f7987b8955b6ce985_cb4a8a449b4ada864625ee5a4355578a3aaf08ed/binaries");
