    function fmi3SetFloat32
      extends Modelica.Icons.Function;
      input fmuModel fmu;
      input Integer refs[:];
      input Real vals[:];
    protected
      Real dummy[size(vals, 1)];
      external "C" fmi_wrapper_fmi3SetFloat32(fmu, refs, size(refs, 1), vals, size(vals, 1), dummy)
      annotation(Include="
